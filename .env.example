# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe Payment Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Google Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Email Configuration (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL="Shashti Karz <updates@shashtikarz.com>"

# Admin Notification Email (receives all admin alerts)
ADMIN_EMAIL=your_admin_email@gmail.com

# App URL (for email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin Panel Authentication
ADMIN_PASSWORD=your_secure_admin_password_here

# Cron Job Security (set any random secret string here)
CRON_SECRET=your_random_secret_here

# Monitoring Security (set the same random secret string in Jenkins and Render)
METRICS_SECRET=your_metrics_secret_here

# Render DevOps Credentials
RENDER_API_KEY=your_render_api_key_here
RENDER_OWNER_ID=your_render_owner_id_here
